{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "_meta": {
    "app": "FormulaFix",
    "version": "1.0.0",
    "description": "Design tokens extracted from UI prototype. Flutter ThemeData maps directly to these tokens.",
    "source": "formulafix-redesign.design/colors_and_type.css",
    "date": "2026-07-18"
  },

  "color": {
    "light": {
      "brand": {
        "primary": "#1E3A5F",
        "primaryForeground": "#FFFFFF",
        "primaryHover": "#16304F",
        "accent": "#E76F51",
        "accentForeground": "#FFFFFF"
      },
      "semantic": {
        "success": "#2D6A4F",
        "warning": "#E9C46A",
        "error": "#C1121F"
      },
      "surface": {
        "background": "#FAFAF7",
        "foreground": "#1A1D23",
        "card": "#FFFFFF",
        "cardForeground": "#1A1D23",
        "muted": "#F0EFEA",
        "mutedForeground": "#6B7280",
        "border": "#E5E4DF",
        "input": "#E5E4DF",
        "ring": "#1E3A5F"
      },
      "editor": {
        "background": "#FDFDFB",
        "line": "#EFEDE6",
        "toolbarBg": "rgba(255,255,255,0.92)",
        "formulaBgStart": "#EBF0F5",
        "formulaBgEnd": "#E8EEF2"
      }
    },
    "dark": {
      "brand": {
        "primary": "#5B8DB8",
        "primaryForeground": "#0F1419",
        "primaryHover": "#7AA5CA",
        "accent": "#F4A261",
        "accentForeground": "#0F1419"
      },
      "semantic": {
        "success": "#52B788",
        "warning": "#E9C46A",
        "error": "#E76F51"
      },
      "surface": {
        "background": "#0F1419",
        "foreground": "#E8EAED",
        "card": "#1A1D23",
        "cardForeground": "#E8EAED",
        "muted": "#242830",
        "mutedForeground": "#9AA0A6",
        "border": "#2A2F38",
        "input": "#2A2F38",
        "ring": "#5B8DB8"
      },
      "editor": {
        "background": "#13171D",
        "line": "#22272F",
        "toolbarBg": "rgba(26,29,35,0.92)",
        "formulaBgStart": "#1E2A36",
        "formulaBgEnd": "#1C2530"
      }
    }
  },

  "radius": {
    "sm": "6px",
    "md": "10px",
    "lg": "16px",
    "xl": "24px"
  },

  "shadow": {
    "sm": "0 1px 2px rgba(26,29,35,0.04)",
    "md": "0 4px 12px rgba(26,29,35,0.06)",
    "lg": "0 12px 40px rgba(26,29,35,0.10)",
    "xl": "0 24px 60px rgba(26,29,35,0.14)",
    "dark": {
      "sm": "0 1px 2px rgba(0,0,0,0.3)",
      "md": "0 4px 12px rgba(0,0,0,0.4)",
      "lg": "0 12px 40px rgba(0,0,0,0.5)",
      "xl": "0 24px 60px rgba(0,0,0,0.6)"
    }
  },

  "typography": {
    "sans": {
      "family": "-apple-system, BlinkMacSystemFont, SF Pro Text, Segoe UI, PingFang SC, Hiragino Sans GB, Microsoft YaHei, sans-serif",
      "use": "UI chrome, meta text, labels, buttons, navigation"
    },
    "serif": {
      "family": "Iowan Old Style, Palatino Linotype, Source Han Serif SC, Songti SC, Georgia, serif",
      "use": "Document body, headings, formulas, titles, numbers"
    },
    "mono": {
      "family": "SF Mono, JetBrains Mono, Fira Code, Consolas, monospace",
      "use": "Inline code, file extensions, source hints, formula source"
    },
    "scale": {
      "editorBody": { "size": "15px", "lineHeight": 1.85, "weight": "400", "font": "serif" },
      "readerBody": { "size": "16px", "lineHeight": 1.9, "weight": "400", "font": "serif" },
      "h1": { "size": "26px", "lineHeight": 1.25, "weight": "700", "font": "serif" },
      "readerH1": { "size": "28px", "lineHeight": 1.25, "weight": "700", "font": "serif" },
      "h2": { "size": "19px", "lineHeight": 1.3, "weight": "600", "font": "serif" },
      "h2Reader": { "size": "20px", "lineHeight": 1.3, "weight": "600", "font": "serif" },
      "sectionHeader": { "size": "18px", "lineHeight": 1.3, "weight": "600", "font": "serif" },
      "cardTitle": { "size": "14px", "lineHeight": 1.4, "weight": "600", "font": "sans" },
      "body": { "size": "13px", "lineHeight": 1.5, "weight": "400", "font": "sans" },
      "meta": { "size": "11px", "lineHeight": 1.4, "weight": "400", "font": "sans" },
      "caption": { "size": "10px", "lineHeight": 1.3, "weight": "400", "font": "sans" },
      "formulaDisplay": { "size": "19px", "lineHeight": 1.4, "weight": "400", "font": "serif" },
      "formulaDisplayReader": { "size": "21px", "lineHeight": 1.4, "weight": "400", "font": "serif" },
      "tabLabel": { "size": "11px", "lineHeight": 1.0, "weight": "500", "font": "sans" },
      "statusBar": { "size": "11px", "lineHeight": 1.0, "weight": "400", "font": "sans" }
    }
  },

  "spacing": {
    "pageHorizontal": "24px",
    "readerHorizontal": "28px",
    "cardPadding": "16px",
    "cardGap": "12px",
    "sectionGap": "24px",
    "paragraphGap": "20px",
    "fabBottomOffset": "88px",
    "tabBarHeight": "64px",
    "topBarHeight": "48px",
    "statusBarHeight": "32px",
    "bottomSheetMaxHeight": "88vh"
  },

  "component": {
    "button": {
      "primary": {
        "background": "{color.light.brand.primary}",
        "foreground": "{color.light.brand.primaryForeground}",
        "radius": "{radius.md}",
        "paddingHorizontal": "20px",
        "paddingVertical": "8px",
        "fontSize": "13px",
        "fontWeight": "500",
        "shadow": "{shadow.sm}"
      },
      "secondary": {
        "background": "{color.light.surface.muted}",
        "foreground": "{color.light.surface.foreground}",
        "radius": "{radius.md}",
        "paddingHorizontal": "12px",
        "paddingVertical": "8px",
        "fontSize": "13px"
      },
      "ghost": {
        "background": "transparent",
        "foreground": "{color.light.surface.mutedForeground}",
        "radius": "50%",
        "size": "36px",
        "iconSize": "18px"
      },
      "fab": {
        "size": "56px",
        "radius": "50%",
        "background": "{color.light.brand.primary}",
        "foreground": "{color.light.brand.primaryForeground}",
        "iconSize": "26px",
        "shadow": "{shadow.lg}"
      }
    },
    "card": {
      "background": "{color.light.surface.card}",
      "border": "1px solid {color.light.surface.border}",
      "radius": "{radius.lg}",
      "shadow": "{shadow.sm}",
      "padding": "{spacing.cardPadding}"
    },
    "tabBar": {
      "height": "{spacing.tabBarHeight}",
      "background": "{color.light.surface.card} with 95% opacity, backdrop-blur",
      "borderTop": "1px solid {color.light.surface.border}",
      "activeColor": "{color.light.brand.primary}",
      "inactiveColor": "{color.light.surface.mutedForeground}",
      "iconSize": "22px",
      "labelSize": "{spacing.tabBarHeight / 5.8}"
    },
    "toggle": {
      "width": "40px",
      "height": "24px",
      "radius": "12px",
      "onBackground": "{color.light.brand.primary}",
      "offBackground": "{color.light.surface.muted}",
      "thumbSize": "20px",
      "thumbColor": "#FFFFFF"
    },
    "formulaBlock": {
      "background": "linear-gradient(135deg, {color.light.editor.formulaBgStart}, {color.light.editor.formulaBgEnd})",
      "borderLeft": "3px solid {color.light.brand.primary}",
      "radius": "{radius.md}",
      "paddingHorizontal": "20px",
      "paddingVertical": "16px",
      "editorFontSize": "19px",
      "readerFontSize": "21px",
      "font": "serif italic"
    },
    "searchPill": {
      "height": "44px",
      "radius": "9999px",
      "background": "{color.light.surface.muted}",
      "iconSize": "16px",
      "placeholderSize": "14px"
    },
    "bottomSheet": {
      "maxHeight": "88vh",
      "cornerRadius": "{radius.xl}",
      "grabberWidth": "40px",
      "grabberHeight": "4px",
      "grabberColor": "{color.light.surface.border}",
      "shadow": "{shadow.xl}"
    },
    "progressBar": {
      "height": "2px",
      "color": "{color.light.brand.primary}"
    }
  }
}
