{
  "name": "@fixmath/core",
  "version": "1.0.0",
  "description": "Cross-platform math formula parsing and export library",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "module": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dart": {
      "dart": "lib/core.dart"
    }
  },
  "files": [
    "dist",
    "lib"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-cjs.js",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
